# ── Dependencies ──────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ─────────────────────────────────────────────
dist/
dist-ssr/
build/
client/dist/

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
server/server.log

# ── Environment variables (secrets) ───────────────────────────
.env
.env.*
!.env.example
# Allow client/.env — only contains public VITE_ vars (no secrets), needed for Vercel build
!client/.env

# ── Uploads / user-generated files ────────────────────────────
server/uploads/

# ── OS files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor directories ────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────
*.local
package-lock.json
